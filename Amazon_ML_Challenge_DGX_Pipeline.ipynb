   "source": [
    "## Step 6 — Download Images\n",
    "\n",
    "Downloads all product images from Amazon CDN using 32 parallel threads.\n",
    "Takes 2-3 hours for train (~300k images) and 1 hour for test (~90k images).\n",
    "\n",
    "If images are already present on disk (e.g. from a previous session at\n",
    "/workspace/multimodal/data/archive/images/), this step will be skipped automatically.\n",
    "\n",
    "Image filenames are derived from the image_link column in the CSV (the URL basename).\n",
    "Example: https://m.media-amazon.com/images/I/116R4t6IioL.jpg -> 116R4t6IioL.jpg"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "73d6aef9",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd, requests, os\n",
    "from concurrent.futures import ThreadPoolExecutor, as_completed\n",
    "from tqdm import tqdm\n",
    "\n",
    "# Check if images already exist from a previous session\n",
    "TRAIN_IMGS = '/workspace/multimodal/data/archive/images/train'\n",
    "TEST_IMGS  = '/workspace/multimodal/data/archive/images/test'\n",
    "\n",
    "if os.path.exists(TRAIN_IMGS) and len(os.listdir(TRAIN_IMGS)) > 1000:\n",
    "    print(f'Train images already exist at {TRAIN_IMGS} ({len(os.listdir(TRAIN_IMGS))} files) — skipping download.')\n",
    "    print(f'Test  images already exist at {TEST_IMGS}  ({len(os.listdir(TEST_IMGS))} files) — skipping download.')\n",
    "else:\n",
    "    # Images not found at archive path — download fresh\n",
    "    TRAIN_IMGS = '/workspace/multimodal/data/train_images'\n",
    "    TEST_IMGS  = '/workspace/multimodal/data/test_images'\n",
    "\n",
    "    def download_images(csv_path, img_dir):\n",
    "        os.makedirs(img_dir, exist_ok=True)\n",
    "        df = pd.read_csv(csv_path)\n",
    "        print(f'Downloading {len(df)} images to {img_dir}...')\n",
    "\n",
    "        def dl(row):\n",
    "            filename = row['image_link'].split('/')[-1]\n",
    "            dst = f'{img_dir}/{filename}'\n",
    "            if os.path.exists(dst):\n",
    "                return 'skip'\n",
    "            try:\n",
    "                r = requests.get(row['image_link'], timeout=10)\n",
    "                if r.status_code == 200:\n",
    "                    with open(dst, 'wb') as f:\n",
    "                        f.write(r.content)\n",
    "                    return 'ok'\n",
    "            except:\n",
    "                pass\n",
    "            return 'fail'\n",
    "\n",
    "        ok = skip = fail = 0\n",
    "        with ThreadPoolExecutor(max_workers=32) as ex:\n",
    "            futs = {ex.submit(dl, r): r for r in df.to_dict('records')}\n",
    "            for f in tqdm(as_completed(futs), total=len(futs)):\n",
    "                s = f.result()\n",
    "                if s == 'ok':   ok   += 1\n",
    "                elif s == 'skip': skip += 1\n",
    "                else:           fail += 1\n",
    "        print(f'Done — ok={ok}  skip={skip}  fail={fail}')\n",
    "\n",
    "    download_images('/workspace/multimodal/data/train.csv', TRAIN_IMGS)\n",
    "    download_images('/workspace/multimodal/data/test.csv',  TEST_IMGS)\n",
    "\n",
    "print(f'\\nTrain images path: {TRAIN_IMGS}')\n",
    "print(f'Test  images path: {TEST_IMGS}')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "5d44d66d",
   "metadata": {},
   "source": [
    "## Step 7 — Preprocessing\n",
    "\n",
    "Filters training rows to only those with a valid entity value and matching unit.\n",
    "Then builds the LLaMA-Factory training JSON with image paths and conversation format.\n",
    "\n",
    "Only rows where the image file actually exists on disk are included.\n",
    "Output: /workspace/multimodal/data/for_finetune_created.json"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0fce37e7",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd, json, os\n",
    "\n",
    "ENTITY_UNITS = {\n",
    "    'item_weight':                   ['gram','kilogram','microgram','milligram','ounce','pound','ton'],\n",
    "    'item_volume':                   ['litre','millilitre','cubic foot','cubic inch','cup','fluid ounce','gallon','pint','quart'],\n",
    "    'voltage':                       ['volt','kilovolt','millivolt'],\n",
    "    'wattage':                       ['watt','kilowatt'],\n",
    "    'maximum_weight_recommendation': ['gram','kilogram','pound','ton'],\n",
    "    'height':                        ['centimetre','foot','inch','metre','millimetre','yard'],\n",
    "    'width':                         ['centimetre','foot','inch','metre','millimetre','yard'],\n",
    "    'depth':                         ['centimetre','foot','inch','metre','millimetre','yard'],\n",
    "}\n",
    "\n",
    "def is_valid(val, entity):\n",
    "    if pd.isna(val) or str(val).strip() == '':\n",
    "        return False\n",
    "    return any(u in str(val).lower() for u in ENTITY_UNITS.get(entity, []))\n",
    "\n",
    "# Filter valid rows\n",
    "df = pd.read_csv('/workspace/multimodal/data/train.csv')\n",
    "print(f'Original rows : {len(df)}')\n",
    "df_v = df[df.apply(lambda r: is_valid(r.get('entity_value', ''), r['entity_name']), axis=1)].copy()\n",
    "df_v.to_csv('/workspace/multimodal/data/processed_train.csv', index=False)\n",
    "print(f'After filter  : {len(df_v)} rows')\n",
    "\n",
    "# Resolve image directory — matches whichever path Step 6 used\n",
    "ARCHIVE_DIR = '/workspace/multimodal/data/archive/images/train'\n",
    "IMG_DIR = ARCHIVE_DIR if os.path.exists(ARCHIVE_DIR) and len(os.listdir(ARCHIVE_DIR)) > 1000 \\\n",
    "          else '/workspace/multimodal/data/train_images'\n",
    "print(f'Using image dir: {IMG_DIR}')\n",
    "\n",
    "# Build LLaMA-Factory training JSON\n",
    "records = []\n",
    "for row in df_v.itertuples():\n",
    "    filename = row.image_link.split('/')[-1]\n",
    "    img = os.path.join(IMG_DIR, filename)\n",
    "    if not os.path.exists(img):\n",
    "        continue\n",
    "    records.append({\n",
    "        'conversations': [\n",
    "            {\n",
    "                'from': 'human',\n",
    "                'value': f\"<image>\\nWhat is the {row.entity_name}? Reply ONLY as 'value unit' e.g. '500 gram'.\"\n",
    "            },\n",
    "            {\n",
    "                'from': 'gpt',\n",
    "                'value': str(row.entity_value).strip()\n",
    "            }\n",
    "        ],\n",
    "        'images': [img]\n",
    "    })\n",
    "\n",
    "out = '/workspace/multimodal/data/for_finetune_created.json'\n",
    "json.dump(records, open(out, 'w'), indent=2)\n",
    "print(f'Training samples: {len(records)}')\n",
    "print(f'Saved to        : {out}')\n",
    "print('Preprocessing complete!')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c713aa8e",
   "metadata": {},
   "source": [
    "## Step 8 — Register Dataset and Create Training Config\n",

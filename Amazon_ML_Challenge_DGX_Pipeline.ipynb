    "    'learning_rate': 1e-4, 'num_train_epochs': 3,\n",
    "    'lr_scheduler_type': 'cosine', 'warmup_ratio': 0.1, 'bf16': True,\n",
    "    'val_size': 0.1, 'per_device_eval_batch_size': 2,\n",

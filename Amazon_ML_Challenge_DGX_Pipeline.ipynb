   "source": [
    "## Step 9 — Patch torchaudio Import in LLaMA-Factory\n",
    "\n",
    "LLaMA-Factory's mm_plugin.py does a bare `import torchaudio` which crashes if torchaudio\n",
    "is not installed. This patches it to a safe try/except so training can proceed without it.\n",
    "\n",
    "Safe to run multiple times — skips the patch if already applied."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fa82be1f",
   "metadata": {},
   "outputs": [],
   "source": [
    "import fileinput\n",
    "\n",
    "path = '/workspace/LLaMA-Factory/src/llamafactory/data/mm_plugin.py'\n",
    "\n",
    "# Read current content to check if already patched\n",
    "with open(path, 'r') as f:\n",
    "    content = f.read()\n",
    "\n",
    "if 'except ImportError' in content:\n",
    "    print('torchaudio patch already applied — skipping.')\n",
    "else:\n",
    "    for line in fileinput.input(path, inplace=True):\n",
    "        if 'import torchaudio' in line:\n",
    "            print('try:\\n    import torchaudio\\nexcept ImportError:\\n    torchaudio = None')\n",
    "        else:\n",
    "            print(line, end='')\n",
    "    print('torchaudio import patched successfully.')"
   ]
  },

    "print(f\"  LoRA   : rank={cfg['lora_rank']}, alpha={cfg['lora_alpha']}, 8-bit\")\n",
    "print(f\"  Epochs : {cfg['num_train_epochs']}\")\n",
    "print(f\"  Batch  : {cfg['per_device_train_batch_size']} x {cfg['gradient_accumulation_steps']} = effective {cfg['per_device_train_batch_size'] * cfg['gradient_accumulation_steps']}\")"
   ]
  },
  {
